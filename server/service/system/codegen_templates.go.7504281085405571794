func buildGoPreviewFiles(ctx codegenContext) []previewFile {
	model := renderGoModel(ctx)
	service := renderGoService(ctx)
	api := renderGoAPI(ctx)
	router := renderGoRouter(ctx)
	return []previewFile{
		{Path: filepath.Join(ctx.BackendModelPath, ctx.BusinessName+".go"), Content: model, Group: "backend"},
		{Path: filepath.Join(ctx.BackendServicePath, ctx.BusinessName+".go"), Content: service, Group: "backend"},
		{Path: filepath.Join(ctx.BackendAPIPath, ctx.BusinessName+".go"), Content: api, Group: "backend"},
		{Path: filepath.Join(ctx.BackendRoutePath, ctx.BusinessName+".go"), Content: router, Group: "backend"},
	}
}

func buildFrontendPreviewFiles(ctx codegenContext) []previewFile {
	return []previewFile{
		{Path: filepath.Join(ctx.FrontendPageDir, "index.tsx"), Content: renderFrontendIndex(ctx), Group: "frontend"},
		{Path: filepath.Join(ctx.FrontendPageDir, "edit.tsx"), Content: renderFrontendEdit(ctx), Group: "frontend"},
		{Path: ctx.FrontendAPIPath, Content: renderFrontendAPI(ctx), Group: "frontend"},
	}
}

func renderGoModel(ctx codegenContext) string {
	var fields []string
	for _, column := range ctx.Columns {
		fields = append(fields, fmt.Sprintf("\t%s %s `json:\"%s\" gorm:\"column:%s\"`", toPascalCase(column.ColumnName), goType(column), toCamelCase(column.ColumnName), column.ColumnName))
	}
	return fmt.Sprintf(`package generated

import "time"

type %s struct {
%s
}

func (%s) TableName() string {
	return "%s"
}
`, ctx.ClassName, strings.Join(fields, "\n"), ctx.ClassName, ctx.Table.TableName)
}

func renderGoService(ctx codegenContext) string {
	likes := make([]string, 0)
	equals := make([]string, 0)
	for _, column := range ctx.QueryColumns {
		item := fmt.Sprintf("\"%s\": \"%s\"", toCamelCase(column.ColumnName), column.ColumnName)
		if column.QueryType == "like" {
			likes = append(likes, item)
		} else {
			equals = append(equals, item)
		}
	}
	return fmt.Sprintf(`package generated

import (
	generatedModel "server/model/generated"
	systemService "server/service/system"
)

func %sList(query map[string]string) (*systemService.PageResult, error) {
	var data []generatedModel.%s
	return systemService.PageList(query, &generatedModel.%s{}, &data, map[string]string{%s}, map[string]string{%s}, "id DESC")
}

func Create%s(data map[string]interface{}) (*generatedModel.%s, error) {
	return systemService.CreateRecord[generatedModel.%s]("%s", data)
}

func Update%s(id string, data map[string]interface{}) (*generatedModel.%s, error) {
	return systemService.UpdateRecord[generatedModel.%s]("%s", id, data)
}

func Delete%s(id string) error {
	return systemService.DeleteRecord(&generatedModel.%s{}, id)
}
`, ctx.ClassName, ctx.ClassName, ctx.ClassName, strings.Join(likes, ", "), strings.Join(equals, ", "), ctx.ClassName, ctx.ClassName, ctx.ClassName, ctx.Table.TableName, ctx.ClassName, ctx.ClassName, ctx.ClassName, ctx.Table.TableName, ctx.ClassName, ctx.ClassName)
}

func renderGoAPI(ctx codegenContext) string {
	return fmt.Sprintf(`package generated

import (
	systemAPI "server/api/system"
	generatedService "server/service/generated"

	"github.com/gin-gonic/gin"
)

func %sList(c *gin.Context) {
	result, err := generatedService.%sList(systemAPI.QueryMap(c))
	systemAPI.SuccessOrFail(c, result, err)
}

func Create%s(c *gin.Context) {
	data, ok := systemAPI.BindJSONMap(c)
	if !ok {
		return
	}
	result, err := generatedService.Create%s(data)
	systemAPI.SuccessOrFail(c, result, err)
}

func Update%s(c *gin.Context) {
	data, ok := systemAPI.BindJSONMap(c)
	if !ok {
		return
	}
	result, err := generatedService.Update%s(c.Param("id"), data)
	systemAPI.SuccessOrFail(c, result, err)
}

func Delete%s(c *gin.Context) {
	systemAPI.SuccessOrFail(c, map[string]interface{}{}, generatedService.Delete%s(c.Param("id")))
}
`, ctx.ClassName, ctx.ClassName, ctx.ClassName, ctx.ClassName, ctx.ClassName, ctx.ClassName, ctx.ClassName, ctx.ClassName)
}

